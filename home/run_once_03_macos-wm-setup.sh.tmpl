#!/usr/bin/env bash
# chezmoi:template:left-delimiter="{{" right-delimiter="}}"
# chezmoi: run_once_ — runs once per content hash (idempotent)
# macOS Window Manager Setup — Sketchybar
# Installs SbarLua, builds helper binaries, downloads Sketchybar app font.

{{- if ne .chezmoi.os "darwin" }}
exit 0  # Not macOS — skip silently
{{- end }}

set -euo pipefail

log()  { echo "[macos-wm-setup] $*"; }
warn() { echo "[macos-wm-setup] WARNING: $*" >&2; }

printf '\n══════════════════════════════════════════════\n'
printf '  macOS Window Manager Setup\n'
printf '══════════════════════════════════════════════\n\n'

# ── Section 1: SIP Detection (MACOS-04) ──────────────────────────────────────

SIP_STATUS="$(csrutil status 2>/dev/null || echo "unknown")"

if echo "$SIP_STATUS" | grep -qi "enabled"; then
  log "⚠ SIP is enabled — some Sketchybar features may be limited"
elif echo "$SIP_STATUS" | grep -qi "disabled"; then
  log "✓ SIP is disabled — full Sketchybar support available"
else
# ── Section 2: Install SbarLua ────────────────────────────────────────────────

SBARLUA_PATHS=(
SBARLUA_INSTALLED=false
for p in "${SBARLUA_PATHS[@]}"; do
  if [[ -f "$p" ]]; then
    SBARLUA_INSTALLED=true
    break
  fi
done

if [[ "$SBARLUA_INSTALLED" == "false" ]]; then
  log "Installing SbarLua..."
  (
    git clone https://github.com/FelixKratz/SbarLua.git /tmp/SbarLua &&
    cd /tmp/SbarLua/ &&
    make install &&
    rm -rf /tmp/SbarLua/
  ) || {
    warn "SbarLua installation failed — sketchybar Lua plugins may not work"
    rm -rf /tmp/SbarLua/ 2>/dev/null || true
  }
else
  log "✓ SbarLua already installed"
fi

# ── Section 3: Build Sketchybar helper binaries ──────────────────────────────

HELPERS_DIR="$HOME/.config/sketchybar/helpers"

if [[ -d "$HELPERS_DIR" ]] && [[ -f "$HELPERS_DIR/Makefile" ]]; then
  log "Building Sketchybar helper binaries..."
  (cd "$HELPERS_DIR" && make) || {
    warn "Helper binary build failed — run 'cd $HELPERS_DIR && make' manually"
  }
else
  log "⚠ Sketchybar helpers dir not yet present — run 'chezmoi apply' first, then re-run:"
  log "  cd $HELPERS_DIR && make"
fi

# ── Section 4: Download Sketchybar app font ──────────────────────────────────

FONT_PATH="$HOME/Library/Fonts/sketchybar-app-font.ttf"

if [[ ! -f "$FONT_PATH" ]]; then
  log "Downloading Sketchybar app font..."
  mkdir -p "$HOME/Library/Fonts"
  curl -fsSL \
    "https://github.com/kvndrsslr/sketchybar-app-font/releases/download/v2.0.5/sketchybar-app-font.ttf" \
    -o "$FONT_PATH" || {
    warn "Font download failed — download manually from:"
    warn "  https://github.com/kvndrsslr/sketchybar-app-font/releases"
  }
else
  log "✓ Sketchybar app font already installed"
fi

# ── Done ──────────────────────────────────────────────────────────────────────

printf '\n══════════════════════════════════════════════\n'
printf '  macOS WM setup complete.\n'
printf '══════════════════════════════════════════════\n\n'
