{{/* Chezmoi-managed .zshrc — OS-conditional template */}}

# ── P10k instant prompt (must stay at top) ──────────────────────
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# ── Environment ─────────────────────────────────────────────────
export LC_ALL=en_US.UTF-8
export LC_CTYPE=C
export EDITOR="nvim"

# ── PATH setup (OS-conditional) ─────────────────────────────────
{{ if eq .chezmoi.os "darwin" -}}
# macOS — Apple Silicon Homebrew
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:$PATH"
{{ end -}}

export GOPATH="$HOME/go"
export PATH="$HOME/bin:$GOPATH/bin:$HOME/.cargo/bin:$PATH"

# ── Oh-My-Zsh ──────────────────────────────────────────────────
export ZSH="$HOME/.oh-my-zsh"
export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=240'
{{ if eq .chezmoi.os "darwin" -}}
export ZSH_HIGHLIGHT_HIGHLIGHTERS_DIR=/opt/homebrew/share/zsh-syntax-highlighting/highlighters
{{ end -}}

POWERLEVEL9K_MODE='awesome-patched'
ZSH_THEME="powerlevel10k/powerlevel10k"

ZSH_TMUX_AUTOSTART=${ZSH_TMUX_AUTOSTART:-false}

plugins=(git ssh-agent zsh-autosuggestions tmux docker)

source "$ZSH/oh-my-zsh.sh"

# ── mise activation (replaces nvm, rbenv, goenv) ───────────────
eval "$(mise activate zsh)"

# ── fzf integration (Ctrl+R, Ctrl+T, Alt+C) ────────────────────
{{ if eq .chezmoi.os "darwin" -}}
[[ -f /opt/homebrew/opt/fzf/shell/key-bindings.zsh ]] && source /opt/homebrew/opt/fzf/shell/key-bindings.zsh
[[ -f /opt/homebrew/opt/fzf/shell/completion.zsh ]]    && source /opt/homebrew/opt/fzf/shell/completion.zsh
{{ else -}}
[[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]] && source /usr/share/doc/fzf/examples/key-bindings.zsh
[[ -f /usr/share/fzf/completion.zsh ]]                 && source /usr/share/fzf/completion.zsh
{{ end -}}

# ── Aliases ─────────────────────────────────────────────────────
alias lg='lazygit'
alias lc='lsd'
alias weather="curl -s wttr.in | lolcat -a -d 5"
alias cm='chezmoi'

# ── P10k source (must stay at bottom) ──────────────────────────
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# ── Local overrides (machine-specific, not tracked by chezmoi) ──
# Create ~/.zshrc.local to add aliases, exports, or secrets
# that should NOT be committed to the dotfiles repo.
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
